def file_ops():
    
    with open("emp.txt", "w") as f:
        f.write("ID: 101, Name: Alice\n")
    
    
    with open("emp.txt", "a") as f:
        f.write("ID: 102, Name: Bob\n")
    
    
    with open("emp.txt", "r") as f:
        print("\nEmployee Details from File:\n" + f.read())

file_ops()


